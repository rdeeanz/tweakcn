{
  "name": "worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply simfas-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply simfas-db --remote",
    "db:seed": "wrangler d1 execute simfas-db --local --file=./migrations/0002_seed.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@simfas/shared": "*",
    "hono": "^4.7.2",
    "exceljs": "^4.4.0",
    "pdf-lib": "^1.17.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250224.0",
    "typescript": "^5.7.3",
    "wrangler": "^3.109.2"
  }
}
